h2. Layer 3: Prometheus Integration

h3. Metrics Exported

|| Metric Name || Type || Description || Labels ||
| {{openbao_pki_cert_valid_count}} | Gauge | Number of valid certificates | mount |
| {{openbao_pki_cert_expiring_count}} | Gauge | Certificates expiring within threshold | mount, threshold_days |
| {{openbao_pki_cert_expired_count}} | Gauge | Number of expired certificates | mount |
| {{openbao_pki_cert_revoked_count}} | Gauge | Number of revoked certificates | mount |
| {{openbao_pki_mount_health}} | Gauge | PKI mount health (1=healthy, 0=unhealthy) | mount |
| {{openbao_pki_acme_endpoint_health}} | Gauge | ACME endpoint status (1=active, 0=inactive) | mount |

h3. Prometheus Configuration

{code:language=yaml|title=prometheus.yml - Scrape Configuration}
global:
  scrape_interval: 60s
  evaluation_interval: 60s

scrape_configs:
  # OpenBao PKI Metrics (via monitoring script output)
  - job_name: 'openbao-pki'
    static_configs:
      - targets: ['localhost:9100']
    file_sd_configs:
      - files:
        - '/path/to/monitoring_reports/pki_metrics.prom'
        refresh_interval: 60s

  # Cert-Manager Metrics (if deployed)
  - job_name: 'cert-manager'
    kubernetes_sd_configs:
      - role: pod
        namespaces:
          names:
            - cert-manager
    relabel_configs:
      - source_labels: [__meta_kubernetes_pod_label_app]
        action: keep
        regex: cert-manager
{code}

h3. Alerting Rules

{code:language=yaml|title=pki_alerts.yml}
groups:
  - name: pki_certificate_lifecycle
    interval: 5m
    rules:
      # Alert if certificates expiring within 30 days
      - alert: CertificateExpiringSoon
        expr: openbao_pki_cert_expiring_count > 0
        for: 1h
        labels:
          severity: warning
          team: platform
        annotations:
          summary: "Certificates expiring soon in {{ $labels.mount }}"
          description: "{{ $value }} certificate(s) expiring within threshold"

      # Alert if certificates have expired
      - alert: CertificateExpired
        expr: openbao_pki_cert_expired_count > 0
        for: 5m
        labels:
          severity: critical
          team: platform
        annotations:
          summary: "Expired certificates detected in {{ $labels.mount }}"
          description: "{{ $value }} certificate(s) have expired"

      # Alert if PKI mount is unhealthy
      - alert: PKIMountUnhealthy
        expr: openbao_pki_mount_health == 0
        for: 5m
        labels:
          severity: critical
          team: platform
        annotations:
          summary: "PKI mount {{ $labels.mount }} is unhealthy"
          description: "Cannot access PKI mount - investigate immediately"

      # Alert if ACME endpoint is down
      - alert: ACMEEndpointDown
        expr: openbao_pki_acme_endpoint_health == 0
        for: 2m
        labels:
          severity: warning
          team: platform
        annotations:
          summary: "ACME endpoint unavailable for {{ $labels.mount }}"
          description: "Automated certificate issuance may be impacted"

      # Alert on high revocation rate
      - alert: HighCertificateRevocationRate
        expr: rate(openbao_pki_cert_revoked_count[1h]) > 5
        for: 10m
        labels:
          severity: warning
          team: security
        annotations:
          summary: "High certificate revocation rate detected"
          description: "Investigate potential security incident"
{code}

